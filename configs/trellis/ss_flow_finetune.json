{
  "models": {
    "denoiser": {
      "name": "SparseStructureFlowModel",
      "args": {
        "resolution": 64,
        "in_channels": 8,
        "out_channels": 8,
        "model_channels": 2048,
        "cond_channels": 1024,
        "num_blocks": 24,
        "num_heads": 16,
        "mlp_ratio": 4,
        "patch_size": 1,
        "pe_mode": "ape",
        "qk_rms_norm": true,
        "use_bf16": true
      }
    }
  },
  "dataset": {
    "name": "ImageConditionedSparseStructureLatent",
    "args": {
      "latent_model": "ss_enc_conv3d_16l8_fp16",
      "min_aesthetic_score": 4.0
    }
  },
  "trainer": {
    "name": "ImageConditionedFlowMatchingCFGTrainer",
    "args": {
      "max_steps": 50000,
      "batch_size_per_gpu": 4,
      "batch_split": 4,
      "optimizer": {
        "name": "AdamW",
        "args": {
          "lr": 2e-5,
          "weight_decay": 0.01,
          "betas": [0.9, 0.999]
        }
      },
      "lr_scheduler": {
        "name": "CosineAnnealingLR",
        "args": {
          "T_max": 50000,
          "eta_min": 1e-6
        }
      },
      "warmup_steps": 1000,
      "ema_rate": [0.9999],
      "grad_clip": {
        "name": "AdaptiveGradClipper",
        "args": {
          "max_norm": 1.0,
          "clip_percentile": 95
        }
      },
      "i_log": 100,
      "i_sample": 2000,
      "i_save": 5000,
      "p_uncond": 0.1,
      "finetune_ckpt": "/workspace/checkpoints/trellis/pretrained/ckpts/ss_flow_img_dit_1_3B_64_bf16"
    }
  },
  "_comment": "Fine-tuning config for TRELLIS.2 Sparse Structure Flow. Key changes from pretrained: lr 2e-5 (down from 1e-4), weight_decay 0.01, cosine LR schedule, 50K max steps. Run on 1x A100 80GB."
}
