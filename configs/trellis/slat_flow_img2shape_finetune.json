{
  "models": {
    "denoiser": {
      "name": "SLatFlowModel",
      "args": {
        "resolution": 512,
        "in_channels": 32,
        "out_channels": 32,
        "model_channels": 2048,
        "cond_channels": 1024,
        "num_blocks": 24,
        "num_heads": 16,
        "mlp_ratio": 4,
        "patch_size": 1,
        "pe_mode": "ape",
        "qk_rms_norm": true,
        "use_bf16": true
      }
    }
  },
  "dataset": {
    "name": "ImageConditionedSLatShapeLatent",
    "args": {
      "latent_model": "shape_vae_next_dc_f16c32_fp16",
      "min_aesthetic_score": 4.0
    }
  },
  "trainer": {
    "name": "ImageConditionedFlowMatchingCFGTrainer",
    "args": {
      "max_steps": 50000,
      "batch_size_per_gpu": 2,
      "batch_split": 8,
      "optimizer": {
        "name": "AdamW",
        "args": {
          "lr": 2e-5,
          "weight_decay": 0.01,
          "betas": [0.9, 0.999]
        }
      },
      "lr_scheduler": {
        "name": "CosineAnnealingLR",
        "args": {
          "T_max": 50000,
          "eta_min": 1e-6
        }
      },
      "warmup_steps": 1000,
      "ema_rate": [0.9999],
      "grad_clip": {
        "name": "AdaptiveGradClipper",
        "args": {
          "max_norm": 1.0,
          "clip_percentile": 95
        }
      },
      "i_log": 100,
      "i_sample": 2000,
      "i_save": 5000,
      "p_uncond": 0.1,
      "finetune_ckpt": "/workspace/checkpoints/trellis/pretrained/ckpts/slat_flow_img2shape_dit_1_3B_512_bf16"
    }
  },
  "_comment": "Fine-tuning config for TRELLIS.2 Shape Flow (img2shape). Larger latents than ss_flow so batch_size=2, batch_split=8. This stage refines exact surface geometry."
}
